# Service account
USER=svc-ops@example.com
PASSWORD=<vault:ops-01/service-account/password>

# Vault entries — pull from HashiCorp Vault, do NOT hardcode
STRIPE_SECRET=<vault:stripe/live>
JWT_SECRET=<vault:jwt/prod-signing-key>

# Endpoints
VPN_HOST=vpn.example.com
SSO_HOST=login.example.com
API_HOST=api.example.com

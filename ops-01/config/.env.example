# Copy to .env and populate from Vault. NEVER commit .env.
# See README for Vault path convention.

# Service account
USER=svc-ops@example.com
PASSWORD=<vault:ops-01/service-account/password>
AUTH_TOKEN=<vault:ops-01/service-account/token>

# Vault-managed secrets
STRIPE_SECRET=<vault:ops-01/stripe/key>
JWT_SECRET=<vault:ops-01/jwt/signing_key>

# Endpoints (see endpoints.yaml for authoritative values)
VPN_HOST=vpn.example.com
SSO_HOST=login.example.com
API_HOST=api.example.com

# Runtime
LOG_LEVEL=info
DEPLOY_ENV=prod
